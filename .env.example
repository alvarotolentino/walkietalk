REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
AUTH_LISTEN_ADDR=0.0.0.0:3001
SIGNALING_LISTEN_ADDR=0.0.0.0:3002

# ZMQ Fan-Out Proxy (PULL/PUB pattern)
ZMQ_PULL_ADDR=tcp://0.0.0.0:5559
ZMQ_PUB_ADDR=tcp://0.0.0.0:5560

# Signaling nodes connect to the proxy at these addresses
ZMQ_PUSH_ADDR=tcp://127.0.0.1:5559
ZMQ_SUB_ADDR=tcp://127.0.0.1:5560
